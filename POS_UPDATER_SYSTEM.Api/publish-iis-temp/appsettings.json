{
  "Updater": {
    "StorageRoot": "Storage",
    "LatestJsonUrl": "http://localhost/updates/latest.json",
    "LiveAppBaseUrl": "http://localhost:5000",
    "CheckIntervalMinutes": 30,
    "MainScriptPattern": "main*.js"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
